{
  "name": "@plasius/ui-foundry-core",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://github.com/Plasius-LTD/ui-foundry#readme",
  "bugs": {
    "url": "https://github.com/Plasius-LTD/ui-foundry/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/ui-foundry.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "@plasius/react-state": "^1.2.1",
    "@plasius/schema": "^1.2.6",
    "@plasius/translations": "^1.0.8",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@plasius/schema": {
      "optional": true
    }
  },
  "devDependencies": {
    "@plasius/react-state": "^1.2.1",
    "@plasius/schema": "^1.2.6",
    "@plasius/translations": "^1.0.8",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5.6",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs,esm --clean",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "publishConfig": {
    "access": "public"
  }
}
