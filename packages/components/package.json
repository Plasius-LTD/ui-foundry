{
  "name": "@plasius/ui-foundry-components",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@plasius/ui-foundry-core": "^0.1.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@plasius/ui-foundry-core": "^0.1.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5.6",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs,esm --clean",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "publishConfig": {
    "access": "public"
  }
}
