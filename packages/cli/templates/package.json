{
  "name": "@plasius/ui-foundry-cli",
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://github.com/Plasius-LTD/ui-foundry#readme",
  "bugs": {
    "url": "https://github.com/Plasius-LTD/ui-foundry/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/ui-foundry.git",
    "directory": "packages/cli/templates"
  },
  "bin": {
    "ui-foundry": "dist/bin.cjs"
  },
  "main": "./dist/bin.cjs",
  "module": "./dist/bin.js",
  "types": "./dist/bin.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/bin.d.ts",
      "import": "./dist/bin.js",
      "require": "./dist/bin.cjs"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^12",
    "prompts": "^2",
    "fast-glob": "^3",
    "fs-extra": "^11",
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "vitest": "^4.0.18",
    "typescript": "^5.6",
    "tsup": "^8"
  },
  "scripts": {
    "build": "tsup src/bin.ts --format cjs,esm --dts --clean",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
