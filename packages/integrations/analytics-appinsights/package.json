{
  "name": "@plasius/ui-foundry-analytics-appinsights",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@plasius/ui-foundry-core": "^0.1.0"
  },
  "devDependencies": {
    "@plasius/ui-foundry-core": "^0.1.0",
    "typescript": "^5.6",
    "tsup": "^8",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs,esm --clean",
    "test": "vitest run src",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "publishConfig": {
    "access": "public"
  }
}
